#!/bin/bash
# Run a command (or shell) with full internet access via a separate network namespace

NS="online"

setup_ns() {
    # Create namespace if it doesn't exist
    if ! ip netns list | grep -q "^$NS"; then
        ip netns add $NS

        # Get your default interface (e.g. wlan0 or eth0)
        IFACE=$(ip route | grep default | awk '{print $5}' | head -1)
        GATEWAY=$(ip route | grep default | awk '{print $3}' | head -1)

        # Create a veth pair: one end in host, one in namespace
        ip link add veth-host type veth peer name veth-ns
        ip link set veth-ns netns $NS

        # Configure host side
        ip addr add 10.200.0.1/24 dev veth-host
        ip link set veth-host up

        # Configure namespace side
        ip netns exec $NS ip addr add 10.200.0.2/24 dev veth-ns
        ip netns exec $NS ip link set veth-ns up
        ip netns exec $NS ip link set lo up
        ip netns exec $NS ip route add default via 10.200.0.1

        # Enable NAT on the host for the namespace
        iptables -t nat -A POSTROUTING -s 10.200.0.0/24 -o $IFACE -j MASQUERADE
        iptables -A FORWARD -i veth-host -o $IFACE -j ACCEPT
        iptables -A FORWARD -i $IFACE -o veth-host -m state --state RELATED,ESTABLISHED -j ACCEPT

        # Enable IP forwarding
        sysctl -w net.ipv4.ip_forward=1 > /dev/null

        # DNS for the namespace
        mkdir -p /etc/netns/$NS
        echo "nameserver 8.8.8.8" > /etc/netns/$NS/resolv.conf
    fi
}

teardown_ns() {
    IFACE=$(ip route | grep default | awk '{print $5}' | head -1)
    iptables -t nat -D POSTROUTING -s 10.200.0.0/24 -o $IFACE -j MASQUERADE 2>/dev/null
    iptables -D FORWARD -i veth-host -o $IFACE -j ACCEPT 2>/dev/null
    iptables -D FORWARD -i $IFACE -o veth-host -m state --state RELATED,ESTABLISHED -j ACCEPT 2>/dev/null
    ip link del veth-host 2>/dev/null
    ip netns del $NS 2>/dev/null
    rm -rf /etc/netns/$NS
}

setup_ns

if [ $# -eq 0 ]; then
    echo "[online] Dropping into an internet-enabled shell. Type 'exit' to leave."
    ip netns exec $NS sudo -u $SUDO_USER bash
else
    ip netns exec $NS sudo -u $SUDO_USER "$@"
fi
